using UnityEngine;
using System.IO.Ports;

public class BirdScript : MonoBehaviour
{
    [Header("Serial Settings")]
    public string portName = "COM8";
    public int baudRate = 115200;

    [Header("Bird Settings")]
    public float flapForce = 4.5f;  // Lower force so it doesn't hit top pipes
    public float gravity = 0.6f;     // Smooth falling speed

    private SerialPort sp;
    private Rigidbody2D rb;

    void Start()
    {
        rb = GetComponent<Rigidbody2D>();

        if (rb == null)
        {
            Debug.LogError("MISSING RIGIDBODY2D: Please attach a Rigidbody2D component!");
            return;
        }

        // Apply comfortable gravity
        rb.gravityScale = gravity;

        try
        {
            sp = new SerialPort(portName, baudRate);
            sp.ReadTimeout = 10;
            sp.Open();
            Debug.Log("<color=green>SUCCESS:</color> Connected to ESP32 on " + portName);
        }
        catch (System.Exception ex)
        {
            Debug.LogError("<color=red>PORT ERROR:</color> " + ex.Message);
        }
    }

    void Update()
    {
        if (sp != null && sp.IsOpen && sp.BytesToRead > 0)
        {
            try
            {
                string signal = sp.ReadLine().Trim();

                if (signal == "FLAP")
                {
                    // Gentle upward pop
                    rb.linearVelocity = new Vector2(rb.linearVelocity.x, flapForce);
                }
            }
            catch (System.Exception)
            {
                // Ignore transient serial read timeouts
            }
        }
    }

    void OnApplicationQuit()
    {
        if (sp != null && sp.IsOpen)
        {
            sp.Close();
        }
    }
}
